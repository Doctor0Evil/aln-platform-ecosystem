TITLE ArtifactRegistryShard2026v1
VERSION 1.0.0
CATEGORY REGISTRY
SUMMARY Canonical shard describing a registered EcoNet artifact and its ecosafety context.

meta
  ownerrepo      string  "aln-platform-ecosystem"
  registryversion string "2026v1"
  issuedutc      string  "2026-05-03T07:15:00Z"
  maintainerdid  string  "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7"
endmeta

enum ArtifactKind2026v1
  BINARY
  KERNEL
  ROUTINE
  QPUDATASHARD
  GOVLOG
  HEALTHCAREPLAN
  INDEXDB
  OTHER
endenum

enum Lane2026v1
