  primaryplane      string
  secondaryplanes   string optional
  lane              Lane2026v1
  kerband           KerBand2026v1
  planecontractid   uint64 optional
  blastradiusid     uint64 optional

  kmetric           float64 optional
  emetric           float64 optional
  rmetric           float64 optional
  vtmax             float64 optional
  kerdeployable     bool

  evidencehex       string
  rohanchorhex      string optional
  signingdid        string
  provenancehex     string optional

  createdutc        datetime
  updatedutc        datetime
