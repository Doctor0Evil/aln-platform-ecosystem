TITLE DefinitionRegistry2026v1
VERSION 1
CATEGORY GOVERNANCE

SUMMARY
Canonical index and governance surface for DR-1 through DR-10
formal definitions. Binds each research direction to its DB
schema, Lyapunov/KER coordinates, and evidence constraints.

meta
  context string VirtaSys.Ecosafety.Definitions
  registryversion string 2026v1
  maintainerdid string bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7
endmeta

record DefinitionEvidenceTag2026v1
  taghex string
  note   string
endrecord

record DefinitionContract2026v1
  defcode       string   // DR1_SQLITE_LYAPUNOV, ...
  scope         string   // LyapunovResidual, TopologyWaste, ...
  dbbinding     string   // dbdefinitionregistry.sql#dr1_shard_residual_view
  description   string

  kfield        string optional
  efield        string optional
  rfield        string optional
  vfield        string optional
  lyapunovrule  string optional

  canalcoord    string optional
  velocityplane string optional

  continuitycoord string optional
  continuitygrade string optional

  lpf_table     string optional
  lpb_table     string optional
  telemetry_table string optional
  telemetry_window_table string optional

  viewname      string optional
endrecord

